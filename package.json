{
  "name": "towrite-open-questions",
  "version": "0.2.6",
  "description": "ToThink and ToWrite annotations for Obsidian writing workflows.",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite build --watch",
    "build": "tsc -p tsconfig.json --noEmit && vite build && node scripts/copy-manifest.mjs",
    "test": "vitest run",
    "deploy:capture": "npm run build && node scripts/deploy-capture.mjs"
  },
  "keywords": [
    "obsidian",
    "open-question",
    "writing",
    "svelte"
  ],
  "author": "Rick",
  "license": "MIT",
  "devDependencies": {
    "@codemirror/state": "6.5.0",
    "@codemirror/view": "6.38.6",
    "@sveltejs/vite-plugin-svelte": "^3.1.2",
    "lucide-svelte": "^0.468.0",
    "obsidian": "^1.6.7",
    "svelte": "^4.2.18",
    "typescript": "^5.5.4",
    "vite": "^5.3.5",
    "vitest": "^2.0.3"
  }
}
